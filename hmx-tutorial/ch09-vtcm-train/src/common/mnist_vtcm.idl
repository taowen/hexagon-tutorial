#ifndef MNIST_VTCM_IDL
#define MNIST_VTCM_IDL

#include "AEEStdDef.idl"
#include "remote.idl"

interface mnist_vtcm : remote_handle64 {
    /* Copy weights from ARM to DSP VTCM (one-time at start) */
    AEEResult init_net(in sequence<uint8> w1, in sequence<uint8> b1,
                       in sequence<uint8> w2, in sequence<uint8> b2);

    /* Train one batch entirely in VTCM.
     * input: [batch_size x 800] float array as bytes
     * labels: [batch_size] uint8 array
     * lr_bits: learning_rate reinterpreted as uint32
     * Returns loss_bits (float as uint32) and correct count */
    AEEResult train_batch(in sequence<uint8> input, in sequence<uint8> labels,
                          in uint32 batch_size, in uint32 lr_bits,
                          rout uint32 loss_bits, rout uint32 correct);

    /* Copy weights from VTCM back to ARM for evaluation */
    AEEResult sync_weights(rout sequence<uint8> w1, rout sequence<uint8> b1,
                           rout sequence<uint8> w2, rout sequence<uint8> b2);

    /* Get DSP timing breakdown (microseconds) */
    AEEResult get_timing(rout uint64 total_us, rout uint64 fwd_mm_us,
                         rout uint64 bwd_mm_us, rout uint64 other_us, rout uint64 sgd_us);
};

#endif
